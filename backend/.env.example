JIRA_BASE_URL=https://jira.zebra.com
JIRA_PAT=replace-with-your-valid-pat
JIRA_PROJECT_KEY=Workforce AppMonitoring
JIRA_CLUSTER_FIELD=customfield_20014
JIRA_CLIENT_ENV_FIELDS=customfield_20034,customfield_20032
JIRA_PAGE_SIZE=100
JIRA_MAX_RESULTS=5000
CACHE_REFRESH_INTERVAL_MINUTES=5
GCP_USERNAME=replace-with-your-gcp-username
GCP_PASSWORD=replace-with-your-gcp-password
DIAGNOSTIC_REMOTE_PATH=/mount/RWS4/batch_jobs/in/
DIAGNOSTIC_SSH_PORT=22
MAX_DIAGNOSTIC_FILE_COUNT=50
DIAGNOSTIC_UPLOADDATA_SCRIPT_PATH=/mount/RWS4/batch_jobs/scripts/uploaddata.sh
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
